{
  "name": "@bhc/game-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --experimental-strip-types src/main.ts",
    "start": "node --experimental-strip-types src/main.ts",
    "build": "node --experimental-strip-types -e \"import('./src/auth/http.ts'); import('./src/lobby/http.ts');\"",
    "test": "node --experimental-strip-types --test src/**/*.test.ts",
    "lint": "node --experimental-strip-types --test src/**/*.test.ts",
    "migrate:up": "node-pg-migrate up --config-file node-pg-migrate.config.js",
    "migrate:down": "node-pg-migrate down --config-file node-pg-migrate.config.js"
  }
}
